# Database
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=sam_database
DB_PORT=3306

# Server
PORT=5000
NODE_ENV=production

# JWT
JWT_SECRET=your-very-long-and-secure-random-secret-key-here
JWT_EXPIRES_IN=7d

# Frontend URL (production'da kaldırabilirsiniz)
FRONTEND_URL=https://sam.guzelteknoloji.com

# Email (opsiyonel)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@guzelteknoloji.com
