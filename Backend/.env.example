# ═══════════════════════════════════════════════════════════════════════════════
# SAM BACKEND - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════════

# 🔐 SECURITY & AUTHENTICATION
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_at_least_32_chars
NODE_ENV=development

# 🗄️ DATABASE
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sam_db
DB_LOGGING=false

# 🌐 SERVER & FRONTEND
PORT=5000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# 📧 EMAIL (Optional - for verification codes, notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@sam-system.com

# 📱 SMS (Optional - Required for SMS integration)
SMS_PROVIDER=netgsm
# SMS_API_KEY=your_sms_api_key
# SMS_SENDER_NAME=SAM_SYSTEM

# 📊 LOGGING
LOG_LEVEL=info

# 🔄 BACKEND SYNC/SCHEDULING
SCHEDULER_INTERVAL=60000

# 🎯 FEATURES (Enable/Disable)
ENABLE_SMS=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_AUDIT_LOGGING=true

# 💾 FILE UPLOAD
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# 🚀 PRODUCTION SETTINGS (Uncomment for production)
# NODE_ENV=production
# NODE_OPTIONS=--max-old-space-size=4096
